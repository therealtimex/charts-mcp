{
    "title": "Missing Data Line Chart",
    "type": "line",
    "data": {
        "type": "fetch",
        "value": "https://gw.alipayobjects.com/os/bmw-prod/551d80c6-a6be-4f3c-a82a-abd739e12977.csv",
        "transform": [
            {
                "type": "map",
                "callback": "(d) => ({ ...d, close: d.date.getUTCMonth() < 3 ? NaN : d.close })"
            }
        ]
    },
    "encode": {
        "x": "date",
        "y": "close"
    },
    "style": {
        "connect": true,
        "connectStroke": "#aaa"
    },
    "format": "html"
}